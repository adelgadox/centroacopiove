# =============================================================================
# Backend — copy to backend/.env
# =============================================================================

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=Acopio API
DEBUG=false

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://app:app@localhost:5432/acopio
# Direct (non-PgBouncer) URL used by Alembic migrations. Leave empty unless you
# put PgBouncer in front of Postgres — then set both this and PGBOUNCER_MODE.
DATABASE_URL_DIRECT=
PGBOUNCER_MODE=false

# ── JWT — generate with: openssl rand -hex 32 ─────────────────────────────────
SECRET_KEY=your-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Encryption — Fernet key for app.utils.crypto (optional) ───────────────────
# Encrypts sensitive DB-stored values.
# Falls back to SECRET_KEY when empty. Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# ── Redis — background jobs (ARQ) + cache ─────────────────────────────────────
# docker compose provides this automatically. Degrades gracefully when unset:
# no-op cache + in-process BackgroundTasks fallback.
REDIS_URL=redis://localhost:6379/0

# ── CORS — comma-separated list of allowed frontend origins ───────────────────
# Production: set to your Vercel URL (e.g. https://acopio.vercel.app)
FRONTEND_URL=http://localhost:3000

# ── Internal API secret — generate with: openssl rand -hex 32 ────────────────
# Shared between Next.js server and FastAPI to protect /internal/* routes
INTERNAL_API_SECRET=your-internal-secret-here

# ── Email — Resend ────────────────────────────────────────────────────────────
RESEND_API_KEY=
MAIL_FROM=noreply@acopio.org
MAIL_FROM_NAME=Acopio

# ── Trusted proxy IPs ─────────────────────────────────────────────────────────
# Railway: use "*" — all traffic passes through Railway's load balancer
TRUSTED_PROXY_IPS=127.0.0.1

# ── Security ──────────────────────────────────────────────────────────────────
# Production: set CLOUDFLARE_ONLY=true to block direct Railway URL access
CLOUDFLARE_ONLY=false
ADMIN_ALLOWED_IPS=

# ── Open Food Facts — barcode lookup (public API, no key needed) ───────────────
# Timeout in seconds for barcode lookups (default 5)
OPEN_FOOD_FACTS_TIMEOUT=5.0

# ── Sentry — backend error tracking (optional) ────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# ── Slack Bot — 500 alert notifications (optional) ────────────────────────────
# Create app at api.slack.com → OAuth & Permissions → Bot Token (xoxb-...)
SLACK_BOT_TOKEN=

# ── Google Safe Browsing — URL reputation checks (optional) ───────────────────
GOOGLE_SAFE_BROWSING_API_KEY=

# ── OAuth — Google (optional) ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# =============================================================================
# Frontend — copy to frontend/.env.local
# =============================================================================

NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here

# FastAPI URL — server-side Next.js calls (can be internal Railway URL in prod)
API_URL=http://localhost:8000
# FastAPI URL — client-side browser calls (must be public/Cloudflare-proxied in prod)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Internal API secret (same value as backend INTERNAL_API_SECRET)
INTERNAL_API_SECRET=your-internal-secret-here

# ── OAuth — Google (optional) ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Sentry — frontend error tracking (optional) ───────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=


# =============================================================================
# OPTIONAL LAYERS — see docs/optional-layers.md for full setup
# =============================================================================

# ── Cloudinary — image / video uploads ───────────────────────────────────────
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ── AI / OpenAI-compatible provider ──────────────────────────────────────────
# AI_API_KEY=
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini

# ── Langfuse — LLM observability ─────────────────────────────────────────────
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

# ── Stripe — payments & subscriptions ────────────────────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID_PRO=

# ── GeoIP / MaxMind — country / city lookup ──────────────────────────────────
# GEOIP_DB_PATH=/data/GeoLite2-City.mmdb

# ── ElevenLabs + Cloudflare R2 — AI voice generation ─────────────────────────
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=https://pub-xxx.r2.dev
